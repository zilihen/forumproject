<!doctype html>
<html lang="en">
  <head>
    <title>Login Page</title>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="/css/style.css" type="text/css">
    <script src="/public/js/home.js" defer></script>
  </head>

  <body>
    <h1>Hello, <%= name %></h1>
    <p>
      <em>Welcome to your dashboard</em>
      <button type="button" onclick="generateJoke()">Generate Joke</button>
      <br>
      <button type="button" onclick="deleteJokes()">Delete All Jokes</button>
      <br>
      <button type="button" onclick="viewJokes()">View Saved Jokes</button>
      <br>
      <a href="/logout" id="logout">Logout</a>
      <br><br>
      <div id="textZone"></div>
      <br>
      <button type = "button" onclick="saveJoke()">Save Joke</button>
    </p>
  </body>
</html>
